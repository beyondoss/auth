{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            s.id,\n            s.token_id,\n            s.ip_address::text   AS ip_address,\n            s.user_agent,\n            s.created_at,\n            tok.expires_at,\n            tok.last_used_at,\n            true                 AS \"current!\"\n        FROM auth.sessions s\n        INNER JOIN auth.tokens tok ON tok.id = s.token_id\n        WHERE s.user_id  = $1\n          AND s.token_id = $2\n          AND tok.expires_at > now()\n        ",
