{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            k.id,\n            k.name,\n            k.created_at,\n            tok.last_used_at,\n            tok.expires_at\n        FROM auth.keys k\n        INNER JOIN auth.tokens tok ON tok.id = k.token_id\n        WHERE k.id      = $1\n          AND k.user_id = $2\n        ",
