  "query": "SELECT id, org_id, invited_by, email::text, role, created_at, expires_at\n           FROM auth.org_invitations\n           WHERE org_id = $1\n             AND expires_at > now()\n             AND ($2::text IS NULL OR id < $2::uuid)\n           ORDER BY id DESC\n           LIMIT $3",
