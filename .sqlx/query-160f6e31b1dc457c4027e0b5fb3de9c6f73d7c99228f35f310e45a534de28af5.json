{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT e.id, e.email::text AS \"email!\", e.verified_at,\n               (e.id = u.primary_email_id) AS \"is_primary!\"\n        FROM auth.emails e\n        INNER JOIN auth.users u ON u.id = e.user_id\n        WHERE e.user_id = $1\n        ORDER BY e.created_at ASC\n        ",
