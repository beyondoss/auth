{
  "db_name": "PostgreSQL",
  "query": "SELECT i.id, i.org_id, o.name as org_name, i.role, i.expires_at\n           FROM auth.org_invitations i\n           JOIN auth.orgs o ON o.id = i.org_id\n           WHERE i.id = $1\n             AND i.token_hash = $2\n             AND i.expires_at > now()",
