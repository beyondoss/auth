{
  "name": "@beyond.dev/auth",
  "version": "0.1.0-dev",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beyondoss/auth.git"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./next": {
      "import": "./dist/next/index.js",
      "types": "./dist/next/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./hono": {
      "import": "./dist/hono/index.js",
      "types": "./dist/hono/index.d.ts"
    },
    "./fastify": {
      "import": "./dist/fastify/index.js",
      "types": "./dist/fastify/index.d.ts"
    },
    "./express": {
      "import": "./dist/express/index.js",
      "types": "./dist/express/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "generate-types": "node scripts/generate-types.mjs && node scripts/generate-react-types.mjs",
    "generate-types:server": "node scripts/generate-types.mjs",
    "generate-types:react": "node scripts/generate-react-types.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@beyond.dev/openapi-react": "^0.1.1",
    "fastify-plugin": "^5.0.1",
    "jose": "^6.2.2",
    "openapi-fetch": "^0.17.0",
    "std-env": "^3.9.0",
    "type-fest": "^4.0.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@hono/node-server": "^1.13.8",
    "@testcontainers/postgresql": "^10.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "express": "^5.1.0",
    "fastify": "^5.3.2",
    "hono": "^4.7.9",
    "jsdom": "^26.0.0",
    "next": "^16.2.4",
    "openapi-typescript": "^7.6.1",
    "oxfmt": "^0.46.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "testcontainers": "^10.0.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "express": ">=4",
    "fastify": ">=4",
    "hono": ">=4",
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
